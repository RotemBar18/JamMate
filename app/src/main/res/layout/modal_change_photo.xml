<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile photo"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="18dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/changePhoto_BTN_choose"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Choose new photo"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_camera"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:iconTint="@color/app_accent"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/changePhoto_BTN_remove"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Remove photo"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_error"
        android:layout_marginTop="14dp"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_trash"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:iconTint="@color/app_error"
        app:strokeColor="@color/app_error"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_error"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/changePhoto_BTN_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_secondary"
        android:layout_marginTop="18dp"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant"/>

</LinearLayout>