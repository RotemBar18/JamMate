<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="18dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/profileOptions_BTN_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="18dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profileOptions_BTN_lightTheme"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/light"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="@color/app_text_main"
            app:backgroundTint="@color/app_surface"
            app:cornerRadius="16dp"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/profileOptions_BTN_darkTheme"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/dark"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textColor="@color/app_text_main"
            app:backgroundTint="@color/app_surface"
            app:cornerRadius="16dp"
            app:strokeColor="@color/app_outline"
            app:strokeWidth="1dp" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/profileOptions_BTN_edit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/edit_profile"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_edit"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:iconTint="@color/app_accent"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/profileOptions_BTN_logout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="18dp"
        android:text="@string/logout"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_error"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_trash"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:iconTint="@color/app_error"
        app:strokeColor="@color/app_error"
        app:strokeWidth="1dp" />

</LinearLayout>