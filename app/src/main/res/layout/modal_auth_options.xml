<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <!-- Swipable handle for the bottom sheet. -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_sheet_handle"
        android:backgroundTint="@color/app_text_secondary" />

    <!-- Smaller branded animation for the modal header. -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/authModal_LOT_animation"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        app:lottie_rawRes="@raw/jam_animation"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/join_the_jam"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/select_how_you_want_to_continue"
        android:textSize="14sp"
        android:textColor="@color/app_text_secondary"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/authModal_BTN_email"
        style="@style/Widget.JamMate.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/continue_with_email"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_mail"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:iconTint="@color/white" />

    <!-- Google provider button with correct ic_google icon. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/authModal_BTN_google"
        style="@style/Widget.JamMate.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/continue_with_google"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_google"
        app:iconSize="24dp"
        app:iconPadding="12dp"
        app:iconTint="@android:color/transparent"
        app:iconTintMode="add"
        app:strokeColor="@color/app_outline" />

</LinearLayout>