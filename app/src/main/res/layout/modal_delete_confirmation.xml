<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/are_you_sure"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="4dp"/>

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/this_action_cannot_be_undone"
        android:textSize="14sp"
        android:textColor="@color/app_text_secondary"
        android:layout_marginBottom="18dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteConfirm_BTN_delete"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/yes"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_error"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:strokeColor="@color/app_error"
        app:strokeWidth="1dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteConfirm_BTN_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:text="@string/cancel"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_secondary"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant" />

</LinearLayout>