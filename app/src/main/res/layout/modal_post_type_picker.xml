<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_sheet_handle"
        android:backgroundTint="@color/app_text_secondary" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What are you posting?"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/postTypePicker_BTN_normal"
        android:layout_width="match_parent"
        android:text="Normal Post"
        app:icon="@drawable/ic_normal_post"
        android:layout_height="50dp"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        android:gravity="center_vertical|start"
        android:paddingStart="20dp"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:iconTint="@color/app_accent"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/postTypePicker_BTN_jam"
        android:layout_width="match_parent"
        android:text="Jam Session"
        app:icon="@drawable/ic_jam_session"
        android:layout_height="50dp"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        android:gravity="center_vertical|start"
        android:paddingStart="20dp"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:iconTint="@color/app_accent"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/postTypePicker_BTN_member"
        android:layout_width="match_parent"
        android:text="Band Member"
        app:icon="@drawable/ic_band_member"
        android:layout_height="50dp"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        android:gravity="center_vertical|start"
        android:paddingStart="20dp"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:iconTint="@color/app_accent"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant"/>

</LinearLayout>