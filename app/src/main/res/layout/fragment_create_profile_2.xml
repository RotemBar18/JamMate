<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/createProfileStep2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfile2_LBL_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/your_music"
            android:textColor="@color/app_text_main"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfile2_LBL_subHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/let_others_know_your_vibe"
            android:textColor="@color/app_text_secondary"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfile2_LBL_header" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfileStep2_LBL_instruments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/instruments"
            android:textColor="@color/app_text_main"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfile2_LBL_subHeader" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/createProfileStep2_CHIPGROUP_instruments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_LBL_instruments">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_ElectricGuitar"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/electric_guitar"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Drums"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="@string/drums"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main"
                tools:ignore="HardcodedText" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Bass"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bass"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Vocals"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="@string/vocals"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Piano"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/piano"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Keys"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/keys"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Saxophone"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saxophone"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Violin"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/violin"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Trumpet"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trumpet"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_AcousticGuitar"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/acoustic_guitar"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_instrument_Cello"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cello"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />
        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfileStep2_LBL_genres"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/genres"
            android:textColor="@color/app_text_main"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_CHIPGROUP_instruments" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/createProfileStep2_CHIPGROUP_genres"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_LBL_genres">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_genre_Rock"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rock"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Indie"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/indie"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Jazz"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/jazz"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Blues"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/blues"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_HipHop"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hip_hop"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Pop"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pop"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Electronic"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/electronic"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Metal"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/metal"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Folk"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/folk"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_RandB"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/r_amp_b"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_Funk"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/funk"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Skill Level Section -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfileStep2_LBL_skill"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/skill_level"
            android:textColor="@color/app_text_main"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_CHIPGROUP_genres" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/createProfileStep2_LBL_skill_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/describe_your_experience_level"
            android:textColor="@color/app_text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_LBL_skill" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/createProfileStep2_CHIPGROUP_skill"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/createProfileStep2_LBL_skill_hint"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_skill_beginner"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/beginner"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_skill_intermediate"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/intermediate"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_skill_advanced"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_skill_Professional"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/professional"
                app:chipBackgroundColor="@color/app_surface"
                app:chipStrokeColor="@color/app_outline"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/app_text_main" />
        </com.google.android.material.chip.ChipGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
