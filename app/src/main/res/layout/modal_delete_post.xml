<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_sheet_round"
    android:backgroundTint="@color/app_surface">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_sheet_handle"
        android:backgroundTint="@color/app_text_secondary" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Post Options"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/app_text_main"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteModal_BTN_delete"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Delete Post"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_error"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_trash"
        app:iconTint="@color/app_error"
        app:iconSize="20dp"
        app:iconPadding="12dp"
        app:strokeColor="@color/app_error"
        app:strokeWidth="1dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteModal_BTN_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/app_text_main"
        app:backgroundTint="@color/app_surface"
        app:cornerRadius="16dp"
        app:strokeColor="@color/app_outline"
        app:strokeWidth="1dp"
        app:rippleColor="@color/app_surface_variant" />

</LinearLayout>