<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- 1. FULL SCREEN MEDIA BACKGROUND -->
    <com.example.jammate.ui.fragments.MediaPreviewView
        android:id="@+id/createPost_MEDIA_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtle gradient overlay for text readability -->
    <View
        android:id="@+id/createPost_VIEW_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_info_overlay"
        android:visibility="gone" />

    <!-- 2. TOP TOOLBAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/createPost_LAY_topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_toolbar_overlay">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/createPost_BTN_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_chevron_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createPost_BTN_typeSelector"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/normal_post"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:icon="@drawable/ic_chevron_right"
            app:iconSize="18dp"
            app:iconGravity="end"
            app:iconTint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createPost_BTN_publish"
            style="@style/Widget.JamMate.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="@string/share"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="19dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3. LIVE EDITOR OVERLAY -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/createPost_LAY_editor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:background="@drawable/bg_info_overlay"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">


            <!-- Location -->
            <LinearLayout
                android:id="@+id/createPost_BTN_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_sheet_round"
                android:backgroundTint="#4DFFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/online_dot"
                    app:tint="@color/white" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/createPost_LBL_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/add_location"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/createPost_LBL_dateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/set_date_amp_time"
                android:textColor="@color/app_accent"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Member fields -->
            <LinearLayout
                android:id="@+id/createPost_LAY_memberFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/seeking_instruments"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/createPost_CHIPS_instruments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true" />
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/preferred_genres"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/createPost_CHIPS_genres"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true" />
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/skill_level"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/createPost_CHIPS_skill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true" />
            </LinearLayout>

            <EditText
                android:id="@+id/createPost_INPUT_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@null"
                android:hint="@string/write_a_caption"
                android:textColorHint="#B3FFFFFF"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:maxLines="5"
                android:inputType="textMultiLine|textCapSentences"
                android:importantForAutofill="no" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 4. INITIAL PICKER OVERLAY -->
    <LinearLayout
        android:id="@+id/createPost_LAY_initialPicker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:background="@color/app_background">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_new_post"
            android:textColor="@color/app_text_main"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createPost_BTN_pickImage"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/select_photo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/app_accent"
            app:icon="@drawable/ic_image"
            app:iconSize="26dp"
            app:iconPadding="12dp"
            app:iconTint="@color/white"
            app:cornerRadius="20dp"
            app:rippleColor="#33FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createPost_BTN_pickVideo"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="20dp"
            android:text="@string/select_video"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/blue"
            app:icon="@drawable/ic_video"
            app:iconSize="26dp"
            app:iconPadding="12dp"
            app:iconTint="@color/white"
            app:cornerRadius="20dp"
            app:rippleColor="#33FFFFFF" />

    </LinearLayout>

    <!-- 5. LOADING OVERLAY (Lottie + Dark Screen) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/createPost_LAY_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/createPost_LOT_loading"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:lottie_rawRes="@raw/jam_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/publishing"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/createPost_LOT_loading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>