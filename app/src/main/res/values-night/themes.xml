<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.JamMate" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/app_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/app_surface_variant</item>
        <item name="colorOnPrimaryContainer">@color/app_text_main</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/app_surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/app_text_main</item>

        <!-- Tertiary color (accents) -->
        <item name="colorTertiary">@color/darkTan</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/app_surface_variant</item>
        <item name="colorOnTertiaryContainer">@color/app_text_main</item>

        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/app_background</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorOnSurface">@color/app_text_main</item>
        <item name="colorSurfaceVariant">@color/app_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/app_text_secondary</item>
        <item name="colorOutline">@color/app_outline</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>